---
import { Icon } from '@astrojs/starlight/components';

interface Props {
	title: string;
	description: string;
	icon: string;
	id?: string;
}

const { title, description, icon, id } = Astro.props;
---

<section class="home-section" id={id}>
	<header class="home-section-header">
		<p class="home-section-eyebrow" aria-hidden="true">
			<Icon name={icon} size="0.9rem" />
		</p>
		<h2 class="home-section-title">{title}</h2>
		<p class="home-section-description">{description}</p>
	</header>
	<slot />
</section>
